# Telegram Bot (обязательно)
BOT_TOKEN=your_bot_token_here
ADMIN_IDS=123456789,987654321

# Copart inventory URL (обязательно)
COPART_URL=https://inventory.copart.io/FTPLSTDM/salesdata.cgi?authKey=YPYU91EI

# --- Локальный запуск (без Docker) ---
# Используются эти переменные
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/auto4export
REDIS_URL=redis://localhost:6379/0

# --- Docker ---
# В Docker DATABASE_URL и REDIS_URL переопределяются в docker-compose
# Эти переменные нужны для postgres и подстановки в compose
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_secure_password
POSTGRES_DB=auto4export
